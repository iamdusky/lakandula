; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LAKANDULA"
config/description="Warcraft-style RTS. Pre-colonial Philippines. Battle of Mactan, 1521."
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
GameSettings="*res://scripts/autoload/game_settings.gd"
ResourceManager="*res://scripts/autoload/resource_manager.gd"
TerrainManager="*res://scripts/autoload/terrain_manager.gd"
TideManager="*res://scripts/autoload/tide_manager.gd"
VictoryManager="*res://scripts/autoload/victory_manager.gd"
SelectionManager="*res://scripts/autoload/selection_manager.gd"
DiplomacyManager="*res://scripts/autoload/diplomacy_manager.gd"
UnitSpawner="*res://scripts/autoload/unit_spawner.gd"
SpanishAI="*res://scripts/autoload/spanish_ai.gd"
TechTree="*res://scripts/autoload/tech_tree.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
Effects="*res://scripts/autoload/effects.gd"
SceneFlow="*res://scripts/autoload/scene_flow.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://assets/ui_theme.tres"

